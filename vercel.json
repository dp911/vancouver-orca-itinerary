{
  "version": 2,
  "name": "vancouver-orca-itinerary",
  "builds": [
    {
      "src": "api/ai-optimize.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/ai-optimize",
      "dest": "api/ai-optimize.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
